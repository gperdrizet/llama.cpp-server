# Copy this file to .env and fill in the values.
#   cp .env.template .env
#
# .env is listed in .gitignore and will not be committed.

# Bearer token required by the llama.cpp server (matches --api-key in the unit file).
API_KEY=your_api_key_here

# Base URL of the server. Change if accessing remotely. Used to access the llama.cpp
# server from testing scripts.
BASE_URL=http://localhost:8502

# Path to llama.cpp server executable.
LLAMA_PATH=your_llama_path_here

# Model directory path.
MODEL_DIR=your_model_dir_here

# Filename of the model to serve.
MODEL=model_file_here.gguf

# CUDA device to use (e.g. "0" or "0,1"). Set to empty string "" to use CPU.
CUDA_DEVICE=0

# Tensor split ratio for multi-GPU inference (e.g. "1,1" for equal split across 2 GPUs).
# Leave empty for single-GPU operation.
TENSOR_SPLIT=

# Context length to use for inference. Should be <= the model's max context length.
# Note: if slots > 1, the effective context length per slot is ctx_size/slots.
CTX_SIZE=model_max_context_here

# Number of layers to load on GPU, set to 0 to load all layers on CPU, or -1 to load
# all layers on GPU.
GPU_LAYERS=-1

# Number of parallel inference slots (--parallel flag). Controls how many requests
# the server processes simultaneously. Each slot gets ctx_size/slots tokens of context.
# Start with 1 (default) and increase after benchmarking with the load test.
SLOTS=1

# Prompt cache size in MiB. Set to 0 to disable caching. Caching can speed up
# inference for repeated prompts.
PROMPT_CACHE_SIZE=0